#!/bin/bash

# laction
# Run GitHub Actions locally with Docker (Privacy focused)
# Usage: laction <workflow-file> <docker-image> [job-name]

set -e

# Colors for TUI
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color
BOLD='\033[1m'

DEBUG=${DEBUG:-false}

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_debug() { if [ "$DEBUG" = "true" ]; then echo -e "${BOLD}[DEBUG]${NC} $1"; fi; }

# Check dependencies
check_deps() {
    for dep in yq docker; do
        if ! command -v "$dep" &> /dev/null; then
            log_error "$dep is required but not installed."
            exit 1
        fi
    done
}

usage() {
    echo -e "${BOLD}Usage:${NC} laction <workflow-file> <docker-image> [job-name]"
    echo -e "Example: laction examples/ci.yml ubuntu:latest"
}

check_deps

WORKFLOW_FILE="$1"
IMAGE="$2"
JOB_NAME="$3"

if [ -z "$WORKFLOW_FILE" ] || [ -z "$IMAGE" ]; then
    usage
    exit 1
fi

if [ ! -f "$WORKFLOW_FILE" ]; then
    log_error "Workflow file '$WORKFLOW_FILE' not found."
    exit 1
fi

# Detect Job Name
if [ -z "$JOB_NAME" ]; then
    JOB_NAME=$(yq -r '.jobs | keys | .[0]' "$WORKFLOW_FILE")
    log_info "No job specified. Using first job: ${BOLD}$JOB_NAME${NC}"
fi

log_info "Preparing job '${BOLD}$JOB_NAME${NC}' from '$WORKFLOW_FILE' in '$IMAGE'..."

CONTAINER_NAME="laction-$(date +%s)"

cleanup() {
    log_info "Stopping container..."
    docker stop "$CONTAINER_NAME" > /dev/null 2>&1 || true
}
trap cleanup EXIT

log_info "Starting Docker container..."
docker run -d --rm -v "$(pwd):/work" -w /work --name "$CONTAINER_NAME" "$IMAGE" sleep infinity > /dev/null

STEP_COUNT=$(yq -r --arg JOB_NAME "$JOB_NAME" '.jobs[$JOB_NAME].steps | length' "$WORKFLOW_FILE")
log_info "Found $STEP_COUNT steps."

for (( i=0; i<$STEP_COUNT; i++ )); do
    echo -e "${BLUE}───────────────────────────────────────────────────${NC}"
    
    STEP_NAME=$(yq -r --arg JOB_NAME "$JOB_NAME" --argjson idx "$i" '.jobs[$JOB_NAME].steps[$idx].name // "Step \($idx + 1)"' "$WORKFLOW_FILE")
    STEP_RUN=$(yq -r --arg JOB_NAME "$JOB_NAME" --argjson idx "$i" '.jobs[$JOB_NAME].steps[$idx].run' "$WORKFLOW_FILE")
    STEP_USES=$(yq -r --arg JOB_NAME "$JOB_NAME" --argjson idx "$i" '.jobs[$JOB_NAME].steps[$idx].uses' "$WORKFLOW_FILE")
    STEP_DUMP=$(yq -r --arg JOB_NAME "$JOB_NAME" --argjson idx "$i" '.jobs[$JOB_NAME].steps[$idx]' "$WORKFLOW_FILE")

    log_debug "Step data: $STEP_DUMP"

    if echo "$STEP_DUMP" | grep -iqE "secrets\.|github\.token"; then
        log_warn "SKIPPING '${BOLD}$STEP_NAME${NC}': Contains secrets."
        continue
    fi

    log_info "▶️  Running '${BOLD}$STEP_NAME${NC}'"

    if [ "$STEP_USES" != "null" ]; then
        log_warn "Action usage '$STEP_USES' detected. (Not supported, skipping)"
        continue
    fi

    if [ "$STEP_RUN" != "null" ]; then
        TMP_SCRIPT=".laction-step-$i.sh"
        echo "#!/bin/sh" > "$TMP_SCRIPT"
        echo "set -e" >> "$TMP_SCRIPT"
        echo "$STEP_RUN" >> "$TMP_SCRIPT"
        chmod +x "$TMP_SCRIPT"
        
        log_debug "Executing script content:\n$STEP_RUN"

        if docker exec "$CONTAINER_NAME" /work/"$TMP_SCRIPT"; then
            log_success "Step completed"
        else
            log_error "Step failed"
            rm -f "$TMP_SCRIPT"
            exit 1
        fi
        rm -f "$TMP_SCRIPT"
    else
        log_warn "No 'run' or 'uses' found. Skipping."
    fi
done

echo -e "${BLUE}───────────────────────────────────────────────────${NC}"
log_success "Job '${BOLD}$JOB_NAME${NC}' completed successfully."

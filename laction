#!/bin/bash
# laction — Run project steps locally in Docker via laction.ini
# Usage: laction [project-path] [profile]

set -e

# ─── Output ───────────────────────────────────────────────────────────────────

GREEN='\033[0;32m'; YELLOW='\033[0;33m'
RED='\033[0;31m'; GRAY='\033[0;90m'; NC='\033[0m'; BOLD='\033[1m'
DEBUG=${DEBUG:-false}

log_info()    { echo -e "${GRAY}info${NC} $1"; }
log_success() { echo -e "${GREEN}done${NC} $1"; }
log_warn()    { echo -e "${YELLOW}warn${NC} $1"; }
log_error()   { echo -e "${RED}fail${NC} $1"; }
log_debug()   { [ "$DEBUG" = "true" ] && echo -e "${GRAY}debug${NC} $1" || true; }

# ─── INI Parser ───────────────────────────────────────────────────────────────

# ini_get <file> <section> <key>
ini_get() {
    local file="$1" section="$2" key="$3" in_section=false
    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        local nows="${line//[[:space:]]/}"
        if [[ "$nows" == "[$section]" ]]; then in_section=true; continue; fi
        if [[ "$nows" == \[* ]]; then in_section=false; continue; fi
        if $in_section && [[ "$nows" == "$key="* ]]; then
            local val="${line#*=}"
            val="${val#"${val%%[![:space:]]*}"}"
            echo "$val"; return
        fi
    done < "$file"
}

# ini_sections <file>
ini_sections() { grep -oP '(?<=\[)[^\]]+' "$1"; }

# ─── Runner Image Mapping ─────────────────────────────────────────────────────

map_image() {
    case "$1" in
        ubuntu-latest|ubuntu-24.04) echo "ubuntu:latest" ;;
        ubuntu-22.04)               echo "ubuntu:22.04"  ;;
        ubuntu-20.04)               echo "ubuntu:20.04"  ;;
        *)                          echo "$1"            ;;
    esac
}

# ─── Usage ────────────────────────────────────────────────────────────────────

usage() {
    echo -e "${BOLD}Usage:${NC} laction [project-path] [profile]"
    echo -e ""
    echo -e "  laction                   run [default] profile in current directory"
    echo -e "  laction ./myproject       run [default] profile in ./myproject"
    echo -e "  laction ./myproject test  run [test] profile in ./myproject"
    echo -e ""
    echo -e "Requires a ${BOLD}laction.ini${NC} in the project directory."
}

# ─── Main ─────────────────────────────────────────────────────────────────────

command -v docker &>/dev/null || { log_error "docker is required but not installed."; exit 1; }

TARGET="${1:-.}"
PROFILE="${2:-default}"

# Resolve project dir
if [ -d "$TARGET" ]; then
    PROJECT_DIR="$(cd "$TARGET" && pwd)"
elif [ -z "$1" ]; then
    PROJECT_DIR="$(pwd)"
else
    log_error "'$TARGET' is not a directory."
    usage; exit 1
fi

INI="$PROJECT_DIR/laction.ini"
[ -f "$INI" ] || { log_error "No laction.ini found in '$PROJECT_DIR'."; usage; exit 1; }

IMAGE=$(ini_get "$INI" "$PROFILE" "image")
RUN=$(ini_get   "$INI" "$PROFILE" "run")

[ -z "$IMAGE" ] && { log_error "No 'image' key in [$PROFILE]."; exit 1; }
[ -z "$RUN"   ] && { log_error "No 'run' key in [$PROFILE].";   exit 1; }

IMAGE=$(map_image "$IMAGE")

log_debug "ini=$INI profile=$PROFILE image=$IMAGE"
log_info  "profile ${BOLD}[$PROFILE]${NC} → ${BOLD}$IMAGE${NC}"
log_info  "run: ${BOLD}$RUN${NC}"
echo -e "${GRAY}───────────────────────────────────────────────────${NC}"

docker run --rm -v "$PROJECT_DIR:/workspace" -w /workspace "$IMAGE" sh -c "$RUN"

echo -e "${GRAY}───────────────────────────────────────────────────${NC}"
log_success "Profile '${BOLD}$PROFILE${NC}' completed."
